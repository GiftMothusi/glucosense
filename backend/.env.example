APP_NAME=GlucoSense API
DEBUG=true
ENVIRONMENT=development

SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/glucosense
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/glucosense

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081","exp://localhost:8081"]

SENTRY_DSN=

STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
